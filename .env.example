# =============================================================================
# Predicto Mobile — environment variables
# =============================================================================
# HOW TO USE
#   1. cp .env.example .env
#   2. Fill in the values below.
#   3. Restart Metro so changes are picked up:  npx expo start -c
#
# EXPO ENV CONVENTIONS
#   • Vars prefixed with `EXPO_PUBLIC_` are inlined into the JS bundle at
#     build time and ARE shipped to the client. Use them only for non-
#     sensitive values (public API URLs, public OAuth client IDs, etc.).
#   • NEVER put server secrets, signing keys, or admin tokens here. The
#     bundle is fully decompilable on a user's device.
#   • Read at runtime via `process.env.EXPO_PUBLIC_FOO`.
#
# Conventions used below:
#   [REQUIRED]   App will not function correctly without it (or warns loudly).
#   [OPTIONAL]   Enables a feature when set; gracefully no-ops otherwise.
#
# Files matching `.env*` are git-ignored (except this `.env.example`).
# =============================================================================


# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------

# [OPTIONAL] Environment tag the app reports to itself. Used by the API
# client to decide whether to log request errors to the console. Values:
# development | staging | production.
# Default: undefined (treated as production-ish — no dev logging)
EXPO_PUBLIC_APP_ENV=development


# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------

# [REQUIRED] Base URL for the Predicto backend (auth, predictions, tickets,
# leaderboard, IAP). The app logs a warning at startup if this is missing.
# Use http://localhost:<port> for local dev. Note: the backend defaults to
# PORT=4000.
#
#   • iOS Simulator    → http://localhost:4000 works as-is
#   • Android emulator → `localhost` is auto-rewritten to 10.0.2.2 by
#                        src/lib/api.ts (the emulator's alias for the host),
#                        so http://localhost:4000 works on Android too
#   • Physical device  → http://<your-LAN-IP>:4000, and start the backend
#                        listening on 0.0.0.0 so the device can reach it
EXPO_PUBLIC_API_URL=http://localhost:4000


# -----------------------------------------------------------------------------
# Google Sign-In
# -----------------------------------------------------------------------------
# Create OAuth 2.0 client IDs in Google Cloud Console
# (https://console.cloud.google.com/apis/credentials):
#   • iOS client      → bundle id `app.predicto.mobile`
#   • Android client  → package `app.predicto.mobile` + your debug SHA-1
#   • Web application → also used by the backend as GOOGLE_CLIENT_ID to
#                       verify the ID token's `aud` claim
#
# All three IDs are public — they're embedded in the bundle. Client secrets
# must NOT live here; the backend doesn't need one either (verification is
# signature-based).
#
# When unset, the "Continue with Google" button shows an alert telling the
# user/developer that Google sign-in is unavailable.

# [OPTIONAL]
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# [OPTIONAL]
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# [OPTIONAL]
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=


# -----------------------------------------------------------------------------
# Push notifications
# -----------------------------------------------------------------------------

# [OPTIONAL] EAS project ID used by Expo Notifications to fetch the device's
# push token. If unset here, the app falls back to the projectId baked into
# app.json's `extra.eas.projectId`; if that's also missing, push registration
# is skipped with a console warning. Setting this here lets a dev build use
# a different EAS project than the committed app.json points at.
EXPO_PUBLIC_PUSH_PROJECT_ID=
