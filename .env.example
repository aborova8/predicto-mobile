# ──────────────────────────────────────────────────────────────────────────────
# Predicto Mobile · Environment Variables (example)
# ──────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file to `.env` (or `.env.local`, `.env.development`, etc.)
#        cp .env.example .env
#   2. Fill in the values below.
#   3. Restart the Expo dev server so changes are picked up:
#        npx expo start -c
#
# IMPORTANT — Expo env conventions:
#   • Variables prefixed with `EXPO_PUBLIC_` are inlined into the JS bundle at
#     build time and ARE shipped to the client. Use them ONLY for non-sensitive
#     values (public API base URLs, public keys, feature flags, etc.).
#   • Anything WITHOUT the `EXPO_PUBLIC_` prefix is only available at build time
#     in tooling/scripts (e.g. EAS, app config) and is NOT exposed to the app.
#   • NEVER put server secrets, signing keys, or admin tokens in EXPO_PUBLIC_*.
#   • Read with `process.env.EXPO_PUBLIC_FOO` from anywhere in the app code.
#
# Files matching `.env*` are git-ignored (except this `.env.example`).
# ──────────────────────────────────────────────────────────────────────────────


# ── App / Runtime ─────────────────────────────────────────────────────────────

# Which environment the app thinks it's running in. Used for logging,
# Sentry tags, banner badges, and disabling certain dev-only features.
# One of: development | staging | production
EXPO_PUBLIC_APP_ENV=development


# ── Backend API ───────────────────────────────────────────────────────────────

# Base URL for the Predicto backend (auth, predictions, tickets, leaderboard).
# Use http://localhost:<port> for local dev, your staging URL otherwise.
# Note: the backend defaults to PORT=4000.
#   • iOS Simulator      → http://localhost:4000 works as-is
#   • Android emulator   → `localhost` is auto-rewritten to 10.0.2.2 by
#                          src/lib/api.ts (the emulator's alias for the host),
#                          so http://localhost:4000 works on Android too
#   • Physical device    → http://<your-LAN-IP>:4000, and start the backend
#                          listening on 0.0.0.0 so the device can reach it
EXPO_PUBLIC_API_URL=http://localhost:4000

# Optional: explicit WebSocket URL for real-time match updates / live odds.
# Leave blank to derive from EXPO_PUBLIC_API_URL.
EXPO_PUBLIC_WS_URL=


# ── Authentication ────────────────────────────────────────────────────────────
# Predicto uses its own backend for auth (email/password, Google, Apple, OTP
# password reset). No third-party auth provider — these vars only need to be
# set if you want to enable Google sign-in.
#
# Create OAuth 2.0 client IDs in Google Cloud Console
# (https://console.cloud.google.com/apis/credentials):
#   • iOS client       → bundle id `app.predicto.mobile`
#   • Android client   → package `app.predicto.mobile` + your debug SHA-1
#   • Web application  → also used by the backend to verify the id_token
#
# All three IDs are public — they're embedded in the bundle. The corresponding
# client secrets must NOT live here; only the backend sees those.

EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=


# ── Sports / odds data provider ───────────────────────────────────────────────
# Public key only — any secret server key MUST live on your backend, not here.

# EXPO_PUBLIC_ODDS_PROVIDER=the-odds-api
# EXPO_PUBLIC_ODDS_API_KEY=your-public-client-key


# ── Payments / paywall ────────────────────────────────────────────────────────
# RevenueCat is the typical Expo-friendly choice for the in-app paywall
# (`src/app/paywall.tsx`). Use the platform-specific public SDK keys.

# EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxx
# EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxx


# ── Analytics & product telemetry ─────────────────────────────────────────────

# PostHog (recommended for funnels / feature flags)
# EXPO_PUBLIC_POSTHOG_KEY=phc_xxx
# EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Mixpanel (alternative)
# EXPO_PUBLIC_MIXPANEL_TOKEN=xxx


# ── Crash & error reporting ───────────────────────────────────────────────────

# Sentry — DSN is safe to ship; AUTH_TOKEN must NOT be `EXPO_PUBLIC_*`
# (it's only used by the build pipeline to upload sourcemaps).
# EXPO_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_AUTH_TOKEN=

# ── Push notifications ────────────────────────────────────────────────────────
# Used by the in-app `notifications.tsx` flow.

EXPO_PUBLIC_PUSH_PROJECT_ID=your-eas-project-id


# ── Feature flags (local overrides) ───────────────────────────────────────────
# Quick toggles for dev. Set to "true" / "false". Anything more sophisticated
# should live in PostHog/LaunchDarkly.

EXPO_PUBLIC_FEATURE_GROUPS=true
EXPO_PUBLIC_FEATURE_PAYWALL=false
EXPO_PUBLIC_FEATURE_LIVE_ODDS=false


# ── Build-time only (NOT shipped to the client) ───────────────────────────────
# These are read by EAS / app config / scripts, never by the running app.

# EAS_PROJECT_ID=
# APPLE_TEAM_ID=
# ANDROID_KEYSTORE_PASSWORD=
